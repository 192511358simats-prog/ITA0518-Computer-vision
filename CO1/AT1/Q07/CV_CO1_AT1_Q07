import cv2
import numpy as np
from google.colab.patches import cv2_imshow

# Create a grayscale gradient image (256 intensity levels)
original = np.tile(np.arange(256, dtype=np.uint8), (256, 1))

# Quantize the image to 16 gray levels
levels = 16
quantized = (original // (256 // levels)) * (256 // levels)

# Display Original Image
print("Original Grayscale Image (256 Gray Levels)")
cv2_imshow(original)

# Display Quantized Image
print("Quantized Image (16 Gray Levels)")
cv2_imshow(quantized)

# Print conclusion
print("\nConclusion:")
print("Quantization converts continuous intensity values into a limited number of gray levels.")
print("Reducing gray levels decreases image detail and creates visible intensity bands.")
print("Higher gray levels preserve more image details, while lower gray levels reduce storage requirements.")
