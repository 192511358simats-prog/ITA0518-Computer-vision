import cv2
import numpy as np
from google.colab.patches import cv2_imshow

# Create a blank image (surveillance scene)
image = np.zeros((400, 600, 3), dtype=np.uint8)

# Draw a white rectangle representing a moving object
cv2.rectangle(image, (220, 120), (380, 300), (255, 255, 255), -1)

# Convert to grayscale
gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)

# Threshold to detect the object
_, thresh = cv2.threshold(gray, 200, 255, cv2.THRESH_BINARY)

# Find contours
contours, _ = cv2.findContours(thresh, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)

# Draw bounding box around detected object
for contour in contours:
    if cv2.contourArea(contour) > 100:
        x, y, w, h = cv2.boundingRect(contour)
        cv2.rectangle(image, (x, y), (x+w, y+h), (0, 255, 0), 2)
        cv2.putText(image, "Detected Object", (x, y-10),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.7, (0, 255, 0), 2)

# Display output
print("Surveillance System Output:")
cv2_imshow(image)

# Classification
print("\nComputer Vision Level : High-Level Computer Vision")
