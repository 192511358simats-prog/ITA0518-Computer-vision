import cv2
import numpy as np
from google.colab.patches import cv2_imshow

# Create a simple grayscale image
image = np.ones((300, 300), dtype=np.uint8) * 180

# Draw shapes
cv2.circle(image, (150, 150), 70, 80, -1)
cv2.rectangle(image, (40, 40), (90, 90), 255, -1)

# Simulate sensor noise (Gaussian Noise)
noise = np.random.normal(0, 25, image.shape).astype(np.int16)
noisy_image = np.clip(image.astype(np.int16) + noise, 0, 255).astype(np.uint8)

# Reduce noise using Gaussian Blur
filtered_image = cv2.GaussianBlur(noisy_image, (5,5), 0)

# Display images
print("Original Image")
cv2_imshow(image)

print("Noisy Image (Sensor Acquisition Noise)")
cv2_imshow(noisy_image)

print("Filtered Image (Noise Reduced)")
cv2_imshow(filtered_image)

# Conclusion
print("\nConclusion:")
print("• During image acquisition, sensors introduce Gaussian noise due to electronic interference and low light.")
print("• Applying Gaussian filtering reduces the noise and improves image quality.")
print("• Better sensors, proper lighting, and image filtering help minimize acquisition noise.")
